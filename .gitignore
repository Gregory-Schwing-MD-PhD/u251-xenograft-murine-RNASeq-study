# Generated metadata: derived from xengsort logs by
# ANALYSIS/build_metadata_from_xengsort.py and rebuilt by run_ruvseq.sh on every
# run. Source of truth = ANALYSIS/metadata_base.csv + the generator script.
ANALYSIS/metadata_full.csv

# Generated by ANALYSIS/ruvseq_contamination_adjustment.R; keep only the README.
ANALYSIS/results_ruvseq/*
!ANALYSIS/results_ruvseq/README.md

# Generated by ANALYSIS/filter_contaminated_genes.R; keep only the README.
ANALYSIS/results_decontamination/*
!ANALYSIS/results_decontamination/README.md

# SLURM job logs
slurm_logs/*
!slurm_logs/.gitkeep

# ------------------------------------------------------------------------------
# Large pipeline data and outputs reused from the upstream run (moved or
# symlinked in from the previous working dir). Never committed -- the repo holds
# the code/config to regenerate them, not the data itself.
# ------------------------------------------------------------------------------
# Raw + sorted reads
DATA/RNASEQ/RAW/downloaded_files/
ANALYSIS/sorted_fastqs/

# xengsort index + per-sample classify logs
ANALYSIS/xengsort_index_clean/
ANALYSIS/xengsort_out/

# nf-core/rnaseq + differentialabundance outputs
ANALYSIS/results_human_final/
ANALYSIS/results_therapy_v3/

# Reference genomes / annotations / pathway databases (downloaded, not authored)
ANALYSIS/refs/

# Nextflow scratch + run state
work/
.nextflow/
.nextflow.log*

# SLURM logs written at the repo root by run_*.sh / submit_*.sh
*.out
*.err
